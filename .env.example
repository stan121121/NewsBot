# ───────────────────────────────────────────
# Telegram Bot
# ───────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ───────────────────────────────────────────
# OpenRouter  →  https://openrouter.ai/keys
# ───────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...

# Модель (менять без пересборки):
# Дешёвые:   google/gemini-flash-1.5   |  meta-llama/llama-3.1-8b-instruct
# Средние:   openai/gpt-4o-mini        |  anthropic/claude-3-haiku
# Сильные:   anthropic/claude-3.5-sonnet | openai/gpt-4o
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ───────────────────────────────────────────
# Настройки дайджеста
# ───────────────────────────────────────────
DEFAULT_DIGEST_INTERVAL_HOURS=4
POSTS_PER_CHANNEL=20
MAX_NEWS_IN_DIGEST=10
DIGEST_LANGUAGE=ru
DB_PATH=bot_data.db
